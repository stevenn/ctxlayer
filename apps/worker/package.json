{
  "name": "@ctxlayer/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "bun ../../scripts/setup-dev-tls.mjs && bun ../../scripts/ensure-dist.mjs",
    "dev": "wrangler dev --https-key-path ../../.dev-tls/localhost-key.pem --https-cert-path ../../.dev-tls/localhost.pem",
    "prebuild": "bun ../../scripts/ensure-dist.mjs",
    "build": "wrangler deploy --dry-run --outdir dist",
    "predeploy": "bun ../../scripts/ensure-dist.mjs",
    "deploy": "wrangler deploy",
    "predeploy:preview": "bun ../../scripts/ensure-dist.mjs",
    "deploy:preview": "wrangler versions upload",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@ctxlayer/shared": "workspace:*",
    "hono": "^4.6.0",
    "js-tiktoken": "^1.0.21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
